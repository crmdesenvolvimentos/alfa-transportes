{
    "name": "crmdesenvolvimentos/alfa-transportes",
    "description": "Cliente PHP para consumir a API de cotação e rastreamento de frete da Alfa Transportes.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "authors": [
        {
            "name": "Célio Martins",
            "email": "crmdesenvolvimentos@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "CrmDesenvolvimentos\\AlfaTransportes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CrmDesenvolvimentos\\AlfaTransportes\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit tests",
        "lint": "find src examples tests -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
